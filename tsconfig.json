{
  "compilerOptions": {
    "target": "ES2018",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2018", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src", "vite.config.ts"]
}
